":"https://ahrkrak.github.io/landscape/logos/37a02ce5cee74c1a74fac419c45b3658ab76f5f9a970e5874712664ccc4e646e.svg","name":"Quobyte","subcategory":"Cloud Native Storage","crunchbase_url":"https://www.crunchbase.com/organization/quobyte","twitter_url":"https://twitter.com/Quobyte"},{"category":"Runtime","homepage_url":"https://robin.io/","id":"runtime--cloud-native-storage--robin-systems","logo_url":"https://ahrkrak.github.io/landscape/logos/7ab22a15860519a4fee408e231ef5f619007eec87211cca4b4c41d4d36ac70d7.svg","name":"Robin Systems","subcategory":"Cloud Native Storage","crunchbase_url":"https://www.crunchbase.com/organization/robin-systems"},{"category":"Runtime","homepage_url":"https://rook.io/","id":"runtime--cloud-native-storage--rook","logo_url":"https://ahrkrak.github.io/landscape/logos/d08d5a49647bd660e74f90a4ff4f46524f35a4463b65090f4bcc513e577922b2.svg","name":"Rook","subcategory":"Cloud Native Storage","accepted_at":"2018-01-29","artwork_url":"https://github.com/cncf/artwork/blob/master/examples/graduated.md#rook-logos","audits":[{"date":"2019-12-01","type":"security","url":"https://drive.google.com/file/d/1rOwrwYmBUpLUm6W5J5rhXvdVit818hWJ/view","vendor":"Trail of Bits"}],"blog_url":"https://blog.rook.io/","crunchbase_url":"https://www.crunchbase.com/organization/cloud-native-computing-foundation","devstats_url":"https://rook.devstats.cncf.io/","graduated_at":"2020-10-07","incubating_at":"2018-09-25","lfx_slug":"rook","maturity":"graduated","repositories":[{"url":"https://github.com/rook/rook","primary":true}],"slack_url":"https://rook-io.slack.com/","stack_overflow_url":"https://stackoverflow.com/questions/tagged/rook","summary":{"business_use_case":" Rook provides a consistent storage platform, whether in the cloud or on bare metal. The storage cluster is managed through Kubernetes Custom Resources, making integrating with your existing DevOps/ GitOps toolset easy.\n For your applications to consume storage, they simply need to use the Kubernetes native approach of creating a `PersistentVolumeClaim`.\n Running a Rook Ceph cluster is made accessible due to the operator pattern.\n The operator pattern allows the Rook project to handle most tasks automatically (e.g., updating to a new Ceph version). These automatic processes reduce the time spent setting up, configuring, maintaining, and updating your Rook storage cluster.","integration":"CSI (Container Storage Interface) Integration, Helm Chart, Prometheus","personas":["SRE/ DevOps Engineers"],"release_rate":"Minor releases: approximately three times a year (similar to Kubernetes cadence), Patch releases: bi-weekly","tags":["Storage","Persistence","Data","CSI","Operator","Kubernetes"],"use_case":" Rook is an open source cloud-native storage orchestrator, providing the platform, framework, and support for Ceph storage to integrate with cloud-native environments natively.\n Ceph is a distributed storage system that provides block, file, and object storage and is deployed in large-scale production clusters.\n Rook automates deployment and management of Ceph to provide self-managing, self-scaling, and self-healing storage services. The Rook operator builds on Kubernetes resources to deploy, configure, provision, scale, upgrade, and monitor Ceph.\n The storage cluster can be run hyper-converged beside your applications, in a cloud, or on bare metal. Rook provides a consistent storage platform anywhere Kubernetes runs."},"tag":["storage"],"twitter_url":"https://twitter.com/rook_io"},{"category":"Runtime","homepage_url":"https://www.szsandstone.com","id":"runtime--cloud-native-storage--sandstone","logo_url":"https://ahrkrak.github.io/landscape/logos/52af3cc05658929e75158bf90c516fb2086cd9a2cb19c269d648b0baf0b1b66f.svg","name":"SandStone","subcategory":"Cloud Native Storage","crunchbase_url":"https://www.crunchbase.com/organization/shansyan-data","description":"ShenZhen SandStone Data Technology Co., Ltd.  is a high-tech enterprise focusing on enterprise-level software-defined st