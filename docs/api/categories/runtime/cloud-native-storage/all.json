omepage_url":"https://kanister.io","id":"runtime--cloud-native-storage--kanister","logo_url":"https://ahrkrak.github.io/landscape/logos/84ee6ae1df9138287c84d02bb7f9d6961e9ac332b179dbabe4b14804cac2107c.svg","name":"Kanister","subcategory":"Cloud Native Storage","accepted_at":"2023-09-20","artwork_url":"https://github.com/cncf/artwork/tree/master/projects/kanister","crunchbase_url":"https://www.crunchbase.com/organization/cloud-native-computing-foundation","devstats_url":"https://kanister.devstats.cncf.io/","lfx_slug":"kanister","maturity":"sandbox","repositories":[{"url":"https://github.com/kanisterio/kanister","primary":true}],"tag":["storage"]},{"category":"Runtime","homepage_url":"https://kasten.io/","id":"runtime--cloud-native-storage--kasten","logo_url":"https://ahrkrak.github.io/landscape/logos/3d6bb035514024a150cc2a728715920d6e9e2e5990a5218a604076e2d9ba2643.svg","name":"Kasten","subcategory":"Cloud Native Storage","crunchbase_url":"https://www.crunchbase.com/organization/kasten"},{"category":"Runtime","homepage_url":"https://www.linbit.com/linstor/","id":"runtime--cloud-native-storage--linstor","logo_url":"https://ahrkrak.github.io/landscape/logos/9bf35aa462767ae0df6c64af25db52fded746daad3676f99979fc31c333d2c3c.svg","name":"LINSTOR","subcategory":"Cloud Native Storage","crunchbase_url":"https://www.crunchbase.com/organization/linbit","description":"High Performance Software-Defined Block Storage for container, cloud and virtualisation. Fully integrated with Docker, Kubernetes, Openstack, Proxmox etc.","repositories":[{"url":"https://github.com/LINBIT/linstor-server","primary":true}],"twitter_url":"https://twitter.com/linbit"},{"category":"Runtime","homepage_url":"https://longhorn.io/","id":"runtime--cloud-native-storage--longhorn","logo_url":"https://ahrkrak.github.io/landscape/logos/acd3d31cbdf0aa2ef2d695fa4a3571e6d232a96214ec33fe0b2022b9719c244c.svg","name":"Longhorn","subcategory":"Cloud Native Storage","accepted_at":"2019-10-11","artwork_url":"https://github.com/cncf/artwork/blob/master/examples/incubating.md#longhorn-logos","crunchbase_url":"https://www.crunchbase.com/organization/cloud-native-computing-foundation","description":"Cloud-native distributed storage for Kubernetes","devstats_url":"https://longhorn.devstats.cncf.io/","incubating_at":"2021-11-04","joined_at":"2019-10-11","lfx_slug":"longhorn","maturity":"incubating","repositories":[{"url":"https://github.com/longhorn/longhorn","primary":true}],"summary":{"business_use_case":"Anyone running a stateful workload, like database, kafka, elasticsearch etc, in a Kubernetes cluster.","integration":"With Kubernetes via CSI.","intro_url":"https://www.youtube.com/watch?v=y0Rs6vghFaU","personas":["Kubernetes users who need persistent storage in their cluster."],"release_rate":"1.0 GA released on May 2020. Latest v1.4.0 was released on Dec 2022.","tags":["kubernetes","storage","csi","backup"],"use_case":"* Highly available persistent storage for Kubernetes\nIn the past, ITOps and DevOps have found it hard to add replicated storage to Kubernetes clusters. As a result many non-cloud-hosted Kubernetes clusters don’t support persistent storage. External storage arrays are non-portable and can be extremely expensive.\nLonghorn delivers simplified, easy to deploy and upgrade, 100% open source, cloud-native persistent block storage without the cost overhead of open core or proprietary alternatives.\n* Easy incremental snapshots and backups\nLonghorn’s built-in incremental snapshot and backup features keep the volume data safe in or out of the Kubernetes cluster.\nScheduled backups of persistent storage volumes in Kubernetes clusters is simplified with Longhorn’s intuitive, free management UI.\n* Cross-cluster disaster recovery\nExternal replication solutions will recover from a disk failure by re-replicating the entire data store. This can take days, during which time the cluster performs poorly and has a higher risk of failure.\nUsing Longhorn, you can control the granularity to the maximum, easily create a disaster recovery volume in another Kubernetes cluster, and failover to it in the event of an emergency.\nIf your main cluster fails, you can bring up the app in the DR cluster quickly with a defined RPO and RTO."},"tag":["storage"]},{"category":"Runtime","homepage_url":"https://min.io/","id":"runtime--cloud-native-storage--minio","logo_url":"https://ahrkrak.github.io/landscape/logos/da1f6718a1f3fb1815a7121a6c4a415ce2aa676812a781d0554ef452fbd83ba4.svg","name":"MinIO","subcategory":"Cloud Native Storage","crunchbase_url":"https://www.crunchbase.com/organization/minio-inc","repositories":[{"url":"https://github.com/minio/minio","primary":true}]},{"category":"Runtime","homepage_url":"https://moosefs.com/","id":"runtime--cloud-native-storage--moosefs","logo_url":"https://ahrkrak.github.io/landscape/logos/7b3f4a7abf66834346762322c62194240accdff6cc37332ec0d774773a8b5eef.svg","name":"MooseFS","subcategory":"Cloud Native Storage","crunchbase_url":"https://www.crunchbase.com/organization/tuxera","repositories":[{"url":"https://github.com/moosefs/moosefs","primary":true}],"twitter_url":"https://twitter.com/moosefs"},{"category":"Runtime","homepage_url":"https://www.netapp.com/data-storage","id":"runtime--cloud-native-storage--netapp","logo_url":"https://ahrkrak.github.io/landscape/logos/1f04787e066102b0bf6497352113d0b29dce24d90cd2ca89621321a0272a1a44.svg","name":"NetApp","subcategory":"Cloud Native Storage","crunchbase_url":"https://www.crunchbase.com/organization/netapp","description":"Build your Data Fabric on the industry’s broadest portfolio of all-flash, hybrid-flash, and object storage systems."},{"category":"Runtime","homepage_url":"https://www.nutanix.com/products/data-services-for-kubernetes","id":"runtime--cloud-native-storage--nutanix-data-services-for-kubernetes-ndk","logo_url":"https://ahrkrak.github.io/landscape/logos/e431a53fad410e45d90fce820e01c56269b184f24b5b97b190ba65ce7fbfd51a.svg","name":"Nutanix Data Services for Kuberne