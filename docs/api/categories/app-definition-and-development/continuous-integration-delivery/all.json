istrate/"},{"category":"App Definition and Development","homepage_url":"https://openchoreo.dev","id":"app-definition-and-development--continuous-integration-delivery--openchoreo","logo_url":"https://landscape.cncf.io/logos/346494abb1cab8c603f7bba3b6fd9b6199dd25c31355447d8b8b75ae40e0daa2.svg","name":"OpenChoreo","subcategory":"Continuous Integration & Delivery","accepted_at":"2026-01-06","artwork_url":"https://github.com/cncf/artwork/tree/master/projects/openchoreo","blog_url":"https://openchoreo.dev/blog/","crunchbase_url":"https://www.crunchbase.com/organization/cloud-native-computing-foundation","description":"A developer platform for Kubernetes that delivers higher-level abstractions with a Backstage-powered portal, CI/CD, GitOps, and built-in observability.","devstats_url":"https://openchoreo.devstats.cncf.io/","lfx_slug":"openchoreo","linkedin_url":"https://www.linkedin.com/company/openchoreo/","maturity":"sandbox","openssf_best_practices_url":"https://www.bestpractices.dev/en/projects/11819","repositories":[{"url":"https://github.com/openchoreo/openchoreo","primary":true}],"slack_url":"https://cloud-native.slack.com/messages/openchoreo/","tag":["app-delivery"],"twitter_url":"https://x.com/openchoreo"},{"category":"App Definition and Development","homepage_url":"https://opengitops.dev/","id":"app-definition-and-development--continuous-integration-delivery--opengitops","logo_url":"https://landscape.cncf.io/logos/0467938e71483d7b6fd46333527eb95ffd377bd90f8a9109ec172b45a1227d7e.svg","name":"OpenGitOps","subcategory":"Continuous Integration & Delivery","accepted_at":"2021-01-26","artwork_url":"https://github.com/cncf/artwork/tree/master/projects/opengitops","crunchbase_url":"https://www.crunchbase.com/organization/cloud-native-computing-foundation","devstats_url":"https://gitopswg.devstats.cncf.io/","lfx_slug":"gitops-wg","maturity":"sandbox","repositories":[{"url":"https://github.com/open-gitops/project","primary":true}],"tag":["app-delivery"],"twitter_url":"https