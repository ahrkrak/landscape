ry":"Runtime","homepage_url":"https://wasmedge.org/","id":"runtime--container-runtime--wasmedge-runtime","logo":"logos/6cdfd38b5fb9f4a31370a6ad4cd495c875775e018c371b6d598114174371fbb3.svg","name":"WasmEdge Runtime","subcategory":"Container Runtime","website":"https://wasmedge.org/","accepted_at":"2021-04-28","additional_categories":[{"category":"Wasm","subcategory":"Runtimes"},{"category":"Wasm","subcategory":"Application Frameworks"},{"category":"AI Native Infra","subcategory":"Workload Runtime"}],"artwork_url":"https://github.com/cncf/artwork/blob/master/examples/sandbox.md#wasmedgeruntime-logos","clomonitor_name":"wasm-edge","clomonitor_report_summary":"images/clomonitor_cncf_wasm-edge.svg","crunchbase_url":"https://www.crunchbase.com/organization/cloud-native-computing-foundation","devstats_url":"https://wasmedge.devstats.cncf.io/","lfx_slug":"wasmedge-runtime","maturity":"sandbox","latest_annual_review_at":"2023-07-04","latest_annual_review_url":"https://github.com/cncf/toc/pull/1109","repositories":[{"url":"https://github.com/WasmEdge/WasmEdge","primary":true}],"summary":{"business_use_case":"WasmEdge improves cloud app’s operational efficiency by providing a secure, portable, fast, and lightweight alternative to traditional Linux containers. It allows microservice or servelsss applications to “scale to zero” — all computing resources can be made available on-demand, and “write once run anywhere”. It also works with existing container management infra and programming languages, and hence minimizing the cost of adoption and migration. It is great for running microservices and serverless functions embedded in data pipelines or SaaS platforms.","integrations":"Crun, Runwasi, Youki, Docker Desktop, Kubernetes, WebAssembly Languages Runtime maintained by VMWare, Proxy-wasm, Knative, SuperEdge, OpenYurt, KubeEdge, Fedora Linux","intro_url":"https://youtu.be/Kg5z5A5wH0A","personas":["Developers","DevOps Engineers"],"release_rate":"Every 3 months","tags":["Edge Cloud","Edge Devices","Container","Embedded runtime","Serverless","UDF","Microservices","Streaming data","OCI Runtime","SaaS"],"use_case":"WasmEdge provides a high-performance, lightweight, secure, and extensible WebAssembly runtime for cloud-native applications. It is an OCI compliant container that is integrated into Docker, containerd, crun and many Kubernetes projects.  Compared with traditional Linux container apps, WasmEdge apps are more secure, more portable, cold-start 100x faster and only take 1/10 of the space.\n"},"tag":["runtime"],"twitter_url":"https://twitter.com/realwasmedge"},{"category":"App Definition and Development","homepage_url":"https://www.daytona.io","id":"app-definition-and-development--application-definition-image-build--daytona","logo":"logos/18eb27193051171345f462db5ae729cdf165eacd6c55fd2a110412f97db18efc.svg","name":"Daytona","subcategory":"Application Definition & Image Build","website":"https://www.daytona.io","additional_categories":[{"category":"AI Native Infra","subcategory":"Workload Runtime"}],"crunchbase_url":"https://www.crunchbase.com/organization/daytona-4480","repositories":[{"url":"https://github.com/daytonaio/daytona","primary":true}],"twitter_url":"https://twitter.com/daytonaio"},{"category":"AI Native Infra","homepage_url":"https://e2b.dev","id":"ai-native-infra--workload-runtime--e2b","logo":"logos/b228863d0a677602500a3a23e10e056e2107f4a8d196a529e2994b6b8bb4ab93.svg","name":"e2b","subcategory":"Workload Runtime","website":"https://e2b.dev","description":"Open-source, secure environment with real-world tools for enterprise-grade agents.","repositories":[{"url":"https://github.com/e2b-dev/infra","primary":true}]}]}