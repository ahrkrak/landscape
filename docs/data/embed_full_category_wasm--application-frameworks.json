{"items":[{"category":"Runtime","homepage_url":"https://wasmedge.org/","id":"runtime--container-runtime--wasmedge-runtime","logo":"logos/6cdfd38b5fb9f4a31370a6ad4cd495c875775e018c371b6d598114174371fbb3.svg","name":"WasmEdge Runtime","subcategory":"Container Runtime","website":"https://wasmedge.org/","accepted_at":"2021-04-28","additional_categories":[{"category":"Wasm","subcategory":"Runtimes"},{"category":"Wasm","subcategory":"Application Frameworks"},{"category":"AI Native Infra","subcategory":"Workload Runtime"}],"artwork_url":"https://github.com/cncf/artwork/blob/master/examples/sandbox.md#wasmedgeruntime-logos","clomonitor_name":"wasm-edge","clomonitor_report_summary":"images/clomonitor_cncf_wasm-edge.svg","crunchbase_url":"https://www.crunchbase.com/organization/cloud-native-computing-foundation","devstats_url":"https://wasmedge.devstats.cncf.io/","lfx_slug":"wasmedge-runtime","maturity":"sandbox","latest_annual_review_at":"2023-07-04","latest_annual_review_url":"https://github.com/cncf/toc/pull/1109","repositories":[{"url":"https://github.com/WasmEdge/WasmEdge","primary":true}],"summary":{"business_use_case":"WasmEdge improves cloud app’s operational efficiency by providing a secure, portable, fast, and lightweight alternative to traditional Linux containers. It allows microservice or servelsss applications to “scale to zero” — all computing resources can be made available on-demand, and “write once run anywhere”. It also works with existing container management infra and programming languages, and hence minimizing the cost of adoption and migration. It is great for running microservices and serverless functions embedded in data pipelines or SaaS platforms.","integrations":"Crun, Runwasi, Youki, Docker Desktop, Kubernetes, WebAssembly Languages Runtime maintained by VMWare, Proxy-wasm, Knative, SuperEdge, OpenYurt, KubeEdge, Fedora Linux","intro_url":"https://youtu.be/Kg5z5A5wH0A","personas":["Developers","DevOps Engineers"],"release_rate":"Every 3 months","tags":["Edge Cloud","Edge Devices","Container","Embedded runtime","Serverless","UDF","Microservices","Streaming data","OCI Runtime","SaaS"],"use_case":"WasmEdge provides a high-performance, lightweight, secure, and extensible WebAssembly runtime for cloud-native applications. It is an OCI compliant container that is integrated into Docker, containerd, crun and many Kubernetes projects.  Compared with traditional Linux container apps, WasmEdge apps are more secure, more portable, cold-start 100x faster and only take 1/10 of the space.\n"},"tag":["runtime"],"twitter_url":"https://twitter.com/realwasmedge"},{"category":"Wasm","homepage_url":"https://www.ambient.run/","id":"wasm--application-frameworks--ambient","logo":"logos/2f69d86bcec792251a395c70e94b8c26f4ec1f3e3edc029903f09369218aa498.svg","name":"Ambient","subcategory":"Application Frameworks","website":"https://www.ambient.run/","crunchbase_url":"https://www.crunchbase.com/organization/ambient-ecfc","repositories":[{"url":"https://github.com/AmbientRun/Ambient","primary":true}]},{"category":"Wasm","homepage_url":"https://github.com/second-state/dapr-sdk-wasmedge","id":"wasm--application-frameworks--dapr-sdk","logo":"logos/102dadb7fe928ea218a0ee028d459bc6b883800203206616f63da82f87a64526.svg","name":"Dapr SDK","subcategory":"Application Frameworks","website":"https://github.com/second-state/dapr-sdk-wasmedge","crunchbase_url":"https://www.crunchbase.com/organization/second-state","member_subcategory":"Silver","repositories":[{"url":"https://github.com/second-state/dapr-sdk-wasmedge","primary":true}]},{"category":"Wasm","homepage_url":"https://eunomia.dev/","id":"wasm--application-frameworks--eunomia-bpf","logo":"logos/49cfb285ac8fe1e275a3c74a9e0c299060022b3c9f0c1aff56b9dbb1f5bbebf1.svg","name":"eunomia-bpf","subcategory":"Application Frameworks","website":"https://eunomia.dev/","repositories":[{"url":"https://github.com/eunomia-bpf/eunomia-bpf","primary":true}],"unnamed_organization":true},{"category":"Wasm","homepa