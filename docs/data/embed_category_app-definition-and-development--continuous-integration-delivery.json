{"classification":{"category":{"name":"App Definition and Development","normalized_name":"app-definition-and-development","subcategories":[{"name":"Continuous Integration & Delivery","normalized_name":"continuous-integration-delivery"}]}},"foundation":"Microsoft OSS","items":[{"category":"App Definition and Development","id":"app-definition-and-development--continuous-integration-delivery--agola","name":"Agola","logo":"logos/a2a511944ebd07ee954084f7e7dbe5fd4d1e456414bb013b3e1a16936584f10e.svg","subcategory":"Continuous Integration & Delivery","website":"https://agola.io","description":"Open Source CI/CD platform with advanced features and architecture. Powerful, reproducible and containerized workflows (called Runs), git based workflow (integrates with all the primary git repositories like GitHub, GitLab, Gitea), restart Runs from failed tasks, user direct runs (test your local changes to a remote Agola server with just one command), distributed and high available by design and runs everywhere (Kubernetes, docker, IaaS, bare metal).","primary_repository_url":"https://github.com/agola-io/agola"},{"category":"App Definition and Development","id":"app-definition-and-development--continuous-integration-delivery--akuity","name":"Akuity","logo":"logos/947b243bdb4c3806ece1360672960a00d3c69010e6527655b8e61449c33104c8.svg","subcategory":"Continuous Integration & Delivery","website":"https://akuity.io","description":"Akuity is the enterprise-grade company for Argo, the open source suite of cloud native application delivery tools. Akuity was founded by                 Argo originators Hong Wang, Jesse Suen and Alexander Matyushentsev, and its mission is to empower DevOps teams to deliver their apps in a               simpler, safer, and faster way. The Akuity Platform provides a best-in-class developer experience with enterprise readiness, and enables                 organizations to modernize their toolchain for the cloud-native era.","member_subcategory":"Silver"},{"category":"App Definition and Development","id":"app-definition-and-development--continuous-integration-delivery--appveyor","name":"Appveyor","logo":"logos/57fe4f9a38df2a92e0866ee1adf80d04f4f8343e9e27a56f4b2a35ecf4769dfe.svg","subcategory":"Continuous Integration & Delivery","website":"https://www.appveyor.com/"},{"category":"App Definition and Development","id":"app-definition-and-development--continuous-integration-delivery--argo","name":"Argo","logo":"logos/ba71fd50cbc06c7bad3554de23cbca4298593141df3842003a94065c209610f4.svg","subcategory":"Continuous Integration & Delivery","website":"https://argoproj.github.io/","description":"Kubernetes-native tools to run workflows, manage clusters, and do GitOps right.","maturity":"graduated","primary_repository_url":"https://github.com/argoproj/argo-cd","tag":["app-delivery"]},{"category":"App Definition and Development","id":"app-definition-and-development--continuous-integration-delivery--aws-codepipeline","name":"AWS CodePipeline","logo":"logos/6ace853147a87dedbeac4f9993d1349d0ff9f6a0d26bbdfc904bab96597f0d67.svg","subcategory":"Continuous Integration & Delivery","website":"https://aws.amazon.com/codepipeline/","description":"AWS CodePipeline is a fully managed continuous delivery service that helps you automate your release pipelines for fast and reliable application and infrastructure updates. CodePipeline automates the build, test, and deploy phases of your release process every time there is a code change, based on the release model you define.","member_subcategory":"Platinum"},{"category":"App Definition and Development","id":"app-definition-and-development--continuous-integration-delivery--azure-pipelines","name":"Azure Pipelines","logo":"logos/17f58af52c308aa0bb688f634b08ee0f56934abb3d2e36d517a25de8ae41f5dd.svg","subcategory":"Continuous Integration & Delivery","website":"https://azure.microsoft.com/en-us/services/devops/pipelines/","description":"Continuously build, test, and deploy to any platform and cloud","member_subc