.com/brigadecore"},{"category":"App Definition and Development","homepage_url":"https://www.keptn.sh","id":"app-definition-and-development--continuous-integration-delivery--keptn","logo":"logos/4f47e9ff27a7943d9a6c4ab76eee79909d37c300af890a1d283d8ea9f6895aae.svg","name":"Keptn","subcategory":"Continuous Integration & Delivery","website":"https://www.keptn.sh","accepted_at":"2020-06-25","archived_at":"2025-09-03","artwork_url":"https://github.com/cncf/artwork/blob/master/examples/archived.md#keptn-logos","crunchbase_url":"https://www.crunchbase.com/organization/cloud-native-computing-foundation","description":"Cloud-native application life-cycle orchestration. Keptn automates your SLO-driven multi-stage delivery and operations & remediation of your applications.","incubating_at":"2022-07-13","lfx_slug":"keptn","maturity":"archived","repositories":[{"url":"https://github.com/keptn/lifecycle-toolkit","primary":true}],"slack_url":"https://cloud-native.slack.com/messages/keptn/","summary":{"business_use_case":"Engineering teams want to have flexibility and choose the best tool for their needs, creating complex pipelines that are hard to control and maintain. Using Keptn, teams can focus on the application code and forget about Deployment complexity and tool integration. Similarly, SREs can enforce their SLOs/SLAs at the application and microservice levels.","integrations":"Any containerized application, OpenTelemetry, Prometheus","personas":["SREs","DevOps & Platform Engineers","Architects","Developers"],"tags":["Application","Container","Microservices","Security","GitOps","Kubernetes","Helm","Observability","CI/CD","SLI","SLO","SLA","Observability"],"use_case":"Keptn supports teams that build their next generation platform on Kubernetes by solving the following 3 major challenges:\n1: Tame observability tool complexity: Keptn unifies access to ALL observability data through a single metrics server\n2: Remove complex delivery pipeline logic: Keptn provides deployment lifecycle tasks natively in Kubernetes\n3: Root cause for deploy change impact: Keptn emits end-2-end telemetry data to understand and troubleshoot deployments"},"tag":["app-delivery"],"twitter_url":"https://twitter.com/keptnproject","youtube_url":"https://www.youtube.com/channel/UCHMn9HyAMeb81bRlaOuZyuQ"},{"category":"Observability and Analysis","homepage_url":"https://ingraind.org/","id":"observability-and-analysis--observability--fonio","logo":"logos/4775bdce8cad12d64380217cecb91e38d2c6570aff67e800600baf3473ff0896.svg","name":"Fonio","subcategory":"Observability","website":"https://ingraind.org/","accepted_at":"2021-03-30","archived_at":"2024-01-31","crunchbase_url":"https://www.crunchbase.com/organization/cloud-native-computing-foundation","lfx_slug":"ingraind","maturity":"archived","repositories":[{"url":"https://github.com/foniod/foniod","primary":true}],"tag":["observability"]},{"category":"Observability and Analysis","homepage_url":"https://openmetrics.io/","id":"observability-and-analysis--observability--openmetrics","logo":"logos/1509d805cf552290ba0723bf85ebea8e0d85eb2e2d4a0eb5c62a3b776a324f4b.svg","name":"OpenMetrics","subcategory":"Observability","website":"https://openmetrics.io/","accepted_at":"2018-08-10","archived_at":"2024-07-02","artwork_url":"https://github.com/cncf/artwork/blob/master/examples/archived.md#openmetrics-logos","crunchbase_url":"https://www.crunchbase.com/organization/cloud-native-computing-foundation","incubating_at":"2022-02-03","lfx_slug":"openmetrics","maturity":"archived","repositories":[{"url":"https://github.com/OpenObservability/OpenMetrics","primary":true}],"slack_url":"https://cloud-native.slack.com/messages/openmetrics","specification":true,"tag":["observability"],"twitter_url":"https://twitter.com/OpenMetricsIO"},{"category":"Observability and Analysis","homepage_url":"https://opentracing.io/","id":"observability-and-analysis--observability--opentracing","logo":"logos/b0d00dd2dfd851136b114f137fb22d192a5666c6fe96dfd5631d22c31