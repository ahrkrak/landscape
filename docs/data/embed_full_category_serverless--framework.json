{"items":[{"category":"App Definition and Development","homepage_url":"https://dapr.io","id":"app-definition-and-development--application-definition-image-build--dapr","logo":"logos/5b3a3f211aae4c129ca1aa9bf3cf52cf12fc7fe5a3c6bc44744ca45ccd697597.svg","name":"Dapr","subcategory":"Application Definition & Image Build","website":"https://dapr.io","accepted_at":"2021-11-09","additional_categories":[{"category":"Wasm","subcategory":"Embedded Functions"},{"category":"Serverless","subcategory":"Framework"}],"artwork_url":"https://github.com/cncf/artwork/blob/master/examples/graduated.md#dapr-logos","audits":[{"date":"2023-06-30","type":"fuzzing","url":"https://docs.dapr.io/docs/Dapr-june-2023-fuzzing-audit-report.pdf","vendor":"Ada Logics"},{"date":"2023-09-05","type":"security","url":"https://docs.dapr.io/docs/Dapr-september-2023-security-audit-report.pdf","vendor":"Ada Logics"}],"blog_url":"https://blog.dapr.io/posts","clomonitor_name":"dapr","clomonitor_report_summary":"images/clomonitor_cncf_dapr.svg","crunchbase_url":"https://www.crunchbase.com/organization/cloud-native-computing-foundation","devstats_url":"https://dapr.devstats.cncf.io/","featured":{"label":"CNCF Graduated","order":1},"graduated_at":"2024-10-30","incubating_at":"2021-11-09","lfx_slug":"dapr","maturity":"graduated","repositories":[{"url":"https://github.com/dapr/dapr","primary":true}],"slack_url":"https://discord.com/invite/ptHhX6jc34","summary":{"business_use_case":"Deliver distributed system applications in half the time. Dapr provides APIs that abstract away the complexity of common challenges developers encounter regularly when building distributed applications. These API building blocks can be leveraged as the need arises - use one, several, or all to develop applications faster and deliver solutions on time. Dapr leverages proven practices for distributed application development that enable developers to build resilient, secured systems. By using Dapr in your application, you adopt these best practices without having to spend time solving common challenges.","integration":"Kubernetes, Docker, Open Telemetry, gRPC, CloudEvents, spiffe, Knative, Helm, Prometheus, Cert Manager","intro_url":"https://youtu.be/9o9iDAgYBA8","personas":["Developers","Platform engineers"],"release_rate":"4 times per year (each quarter)","tags":["Developer APIs","Distributed Systems","Microservices","HTTP","gRPC","Go","Java","Python",".NET","Javascript","C++","Rust","CLI"],"use_case":"The Distributed Application Runtime (Dapr) provides APIs that simplify microservice architecture development and increases developer productivity. Whether your communication pattern is service-to-service invocation or pub/sub messaging, Dapr helps you write resilient and secured microservices. By letting Dapr’s sidecar take care of the complex challenges such as service discovery, message broker integration, encryption, observability, and secret management, developers can focus on business logic and keep their code simple."},"tag":["app-delivery"],"twitter_url":"https://twitter.com/DaprDev"},{"category":"Serverless","homepage_url":"https://arc.codes/docs/en/get-started/quickstart","id":"serverless--framework--architect","logo":"logos/f765cb50debc802115be8d22c8ceea932fdae3735652a1ab28722ea7b3cfc5ee.svg","name":"Architect","subcategory":"Framework","website":"https://arc.codes/docs/en/get-started/quickstart","crunchbase_url":"https://www.crunchbase.com/organization/open-js-foundation","repositories":[{"url":"https://github.com/architect/functions","primary":true}]},{"category":"Serverless","homepage_url":"https://aws.amazon.com/serverless/sam/","id":"serverless--framework--aws-server-application-model-sam","logo":"logos/8b8ed8d87b21b8f9b9a27cc262955febd5008a927ab69b47acb5927e6c85d4b5.svg","name":"AWS Server Application Model (SAM)","subcategory":"Framework","website":"https://aws.amazon.com/serverless/sam/","crunchbase_url":"https://www.crunchbase.com/organization/amazon-web-services","member_subcategor